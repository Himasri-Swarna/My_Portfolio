rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Validation Helpers
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function isValidInquiry(data) {
      return data.keys().hasAll(['name', 'email', 'subject', 'message', 'createdAt'])
        && data.keys().size() == 5
        && data.name is string && data.name.size() >= 1 && data.name.size() <= 256
        && data.email is string && data.email.size() >= 3 && data.email.size() <= 256
        && data.subject is string && data.subject.size() >= 1 && data.subject.size() <= 256
        && data.message is string && data.message.size() >= 10 && data.message.size() <= 10000
        && data.createdAt is timestamp;
    }

    // Inquiries Collection rules
    match /inquiries/{inquiryId} {
      allow create: if isValidId(inquiryId) && isValidInquiry(request.resource.data) && request.resource.data.createdAt == request.time;
      allow read, update, delete: if false; // Strict PII protection: nobody can scrape sent inquiries
    }
  }
}
